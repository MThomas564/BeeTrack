{
  "name": "bee-track",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "runLocal": "concurrently \"npm run dev-node\" \"npm run dev\"",
    "dev": "ng serve --proxy-config proxy.conf.json --open",
    "dev-node": "tsx watch src/server",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "build:server": "tsc -p tsconfig.server.json",
    "start:server": "nodemon --watch src/server --exec ts-node src/server/index.ts",
    "start:dev": "concurrently \"npm run start\" \"npm run start:server\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@angular/service-worker": "^21.2.5",
    "@popperjs/core": "^2.11.6",
    "@primeuix/themes": "^2.0.3",
    "compression": "^1.7.4",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "pg": "^8.12.0",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.5",
    "remult": "^0.26.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "~21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@angular/localize": "^21.2.5",
    "@playwright/test": "^1.50.0",
    "@testing-library/angular": "^17.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.5.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^14.4.0",
    "tsx": "^3.12.3",
    "typescript": "~5.9.2"
  }
}
